rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Portfolio photos — publicly readable (shown on landing page to all visitors),
    // but only authenticated app sessions can upload or delete.
    match /portfolio/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Everything else — auth required for both read and write.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

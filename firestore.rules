rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Requires a signed-in session (the app signs in anonymously on load automatically).
    // This blocks random internet access but does not distinguish between the 5 team
    // members individually — anyone with the app URL gets read/write to all app data.
    match /appState/{document} {
      allow read, write: if request.auth != null;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Open read/write — app-level PIN auth protects access at the UI layer.
    // The Firebase project ID (embedded in the bundle) restricts access to app users.
    match /appState/{document} {
      allow read, write: if true;
    }
    match /quotes/{document} {
      allow create: if true;
      allow read, write: if true;
    }
  }
}
